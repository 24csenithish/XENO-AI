# .env.example
APP_NAME=XENO AI
APP_VERSION=1.0.0
DEBUG=false

OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3.5:0.8b
OLLAMA_TIMEOUT=60
OLLAMA_STREAM=true

DATABASE_URL=sqlite:///storage/xeno.db

SHORT_TERM_MESSAGE_LIMIT=12
LONG_TERM_MEMORY_ENABLED=true
MAX_CONTEXT_TOKENS=4096

RAG_ENABLED=false
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_TOP_K=4

ENABLE_PYTHON_TOOL=false
ENABLE_SYSTEM_INFO_TOOL=true